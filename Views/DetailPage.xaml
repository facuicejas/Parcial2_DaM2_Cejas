<?xml version="1.0" encoding="utf-8" ?>
<ContentPage 
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Parcial2.Views.DetailPage"
    Title="Editar un juego">

    <VerticalStackLayout Padding="20">
        <Entry
            Placeholder="Nombre"
            Text="{Binding Game.Name}" />

        
        <Entry
            Placeholder="Genero"
            Text="{Binding Game.Genre}" />

        
        <Entry
            Placeholder="Desarrollador"
            Text="{Binding Game.Developer}" />

       
        <Entry
            Placeholder="Publicador"
            Text="{Binding Game.Publisher}" />

       
        <Button
            Text="Guardar Cambios"
            Command="{Binding UpdateGameCommand}" />
    </VerticalStackLayout>

</ContentPage>